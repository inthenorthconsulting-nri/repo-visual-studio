{
  "name": "editorial-light",
  "version": "1.0.0",
  "colors": {
    "background": "#faf7f2",
    "surface": "#ffffff",
    "text_primary": "#20201d",
    "text_secondary": "#6b6459",
    "accent": "#c1541f",
    "border": "#e4ddd0",
    "success": "#3a7d5c",
    "warning": "#b5822a"
  },
  "typography": {
    "display": "'Fraunces', Georgia, serif",
    "heading": "'Fraunces', Georgia, serif",
    "body": "'Source Sans 3', 'Helvetica Neue', sans-serif",
    "code": "'IBM Plex Mono', 'SFMono-Regular', monospace"
  },
  "spacing": {
    "unit": 8
  },
  "motion": {
    "fast": 180,
    "normal": 320,
    "slow": 560
  }
}
